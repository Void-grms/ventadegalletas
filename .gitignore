# Dependencias
node_modules/

# package-lock.json no se versiona: el lock generado en Windows no incluye las
# bundleDependencies opcionales multiplataforma (@emnapi/*) de
# @tailwindcss/oxide-wasm32-wasi, y eso rompe `npm ci` en Linux (Railway).
# Sin lock en el repo, Railway/railpack usa `npm install`, que resuelve bien.
package-lock.json

# Salidas de build (Astro)
dist/
.astro/
.output/

# Cache y temporales
.cache/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Entorno
.env
.env.*
!.env.example

# Sistema operativo
.DS_Store
Thumbs.db
desktop.ini

# Editores
.vscode/*
!.vscode/extensions.json
.idea/

# Claude Code (config local del usuario)
.claude/settings.local.json
