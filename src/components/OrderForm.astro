---
import { BOXES } from '../data/boxes';
import { WA_DISPLAY } from '../config/site';
---

<div class="order-shell reveal">
  <div class="order-info">
    <span class="eyebrow">Hacer un pedido</span>
    <h2>Arma tu caja y envíala por WhatsApp</h2>
    <p>Completa estos datos esenciales. Al enviar, se abrirá WhatsApp con tu pedido ya escrito — solo confirmas.</p>
    <div class="mini">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
        <path d="M.057 24l1.687-6.163A11.867 11.867 0 0 1 .16 11.89C.16 5.335 5.495 0 12.05 0c6.555 0 11.89 5.335 11.89 11.892S18.605 23.78 12.05 23.78a11.9 11.9 0 0 1-5.688-1.448z"/>
      </svg>
      {WA_DISPLAY}
    </div>
    <div class="mini">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
        <circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>
      </svg>
      Respondemos rápido en horario de atención
    </div>
    <div class="mini">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
        <path d="M12 21s-7-4.35-9.5-8.5C.8 9.6 2.3 6 5.5 6 7.5 6 9 7.5 12 10c3-2.5 4.5-4 6.5-4 3.2 0 4.7 3.6 3 6.5C19 16.65 12 21 12 21z"/>
      </svg>
      Hechas con amor, para compartir felicidad
    </div>
  </div>

  <form class="form-card" id="order-form" novalidate>

    <!-- Presentación -->
    <div class="field">
      <label>Elige tu presentación <span class="req">*</span></label>
      <div class="choice-grid">
        {BOXES.map((box) => (
          <label class="choice" data-box={box.key}>
            <input type="radio" name="caja" value={box.key} />
            <span class="tick">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                <path d="M20 6L9 17l-5-5"/>
              </svg>
            </span>
            <span class="c-name">{box.name.replace('Caja ', '')}</span>
            <span class="c-meta">{box.cookies} galletas</span>
            <span class="c-price">S/{box.price}</span>
          </label>
        ))}
      </div>
    </div>

    <!-- Sabor -->
    <div class="field">
      <label>Sabor <span class="req">*</span></label>
      <div class="flavor-grid">
        <label class="flavor choice" data-flavor="vainilla">
          <input type="radio" name="sabor" />
          <span class="c-name">Vainilla</span>
        </label>
        <label class="flavor choice" data-flavor="chocolate">
          <input type="radio" name="sabor" />
          <span class="c-name">Chocolate</span>
        </label>
        <label class="flavor choice sel" data-flavor="mixto">
          <input type="radio" name="sabor" checked />
          <span class="c-name">Mixto</span>
        </label>
      </div>
    </div>

    <!-- Cantidad + Fecha -->
    <div class="row-2">
      <div class="field">
        <label for="qty">Cantidad de cajas <span class="req">*</span></label>
        <div class="qty">
          <button type="button" data-step="-1" aria-label="Restar">−</button>
          <input id="qty" type="number" value="1" min="1" max="50" inputmode="numeric" />
          <button type="button" data-step="1" aria-label="Sumar">+</button>
        </div>
      </div>
      <div class="field">
        <label for="fecha">Fecha deseada <span style="color:var(--ink-faint);font-weight:500">(opcional)</span></label>
        <input id="fecha" name="fecha" type="date" class="input" />
      </div>
    </div>

    <!-- Resumen total -->
    <div class="summary">
      <div>
        <span class="lbl">Total estimado</span>
        <div id="count-note" style="font-size:.82rem;color:var(--ink-faint)"></div>
      </div>
      <span class="tot" id="total"><span class="cur">S/</span>5</span>
    </div>

    <!-- Nombre + Teléfono -->
    <div class="row-2">
      <div class="field">
        <label for="nombre">Tu nombre <span class="req">*</span></label>
        <input id="nombre" name="nombre" type="text" class="input" placeholder="Ej. María Pérez" autocomplete="name" />
      </div>
      <div class="field">
        <label for="telefono">Tu teléfono <span class="req">*</span></label>
        <input id="telefono" name="telefono" type="tel" class="input" placeholder="Ej. 999 888 777" autocomplete="tel" inputmode="tel" />
      </div>
    </div>

    <!-- Distrito -->
    <div class="field">
      <label for="entrega">Distrito / zona de entrega <span class="req">*</span></label>
      <input id="entrega" name="entrega" type="text" class="input" placeholder="Ej. Miraflores, Lima" />
    </div>

    <!-- Notas -->
    <div class="field">
      <label for="notas">Notas para tu pedido <span style="color:var(--ink-faint);font-weight:500">(opcional)</span></label>
      <textarea id="notas" name="notas" class="textarea" placeholder="¿Es para regalo? ¿Alguna preferencia especial?"></textarea>
    </div>

    <!-- Submit -->
    <button type="submit" class="btn btn-wa btn-lg" style="width:100%">
      <svg viewBox="0 0 24 24" fill="currentColor">
        <path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 0 1 8.413 3.488 11.824 11.824 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.51 5.26l-.999 3.648 3.978-1.044zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/>
      </svg>
      Enviar pedido por WhatsApp
    </button>
    <p class="form-note">Al enviar se abrirá WhatsApp con tu pedido listo. No se guarda ningún dato en la web.</p>

  </form>
</div>
