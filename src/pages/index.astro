---
import BaseLayout from '../layouts/BaseLayout.astro';
import { PRICING } from '../data/boxes';
import { DELIVERY } from '../config/site';
---
<BaseLayout
  title="Galletas — Hechas con amor"
  description={`Galletas artesanales hechas con amor. Caja de 6 galletas a S/${PRICING.unit}, o 2 cajas por S/${PRICING.pair}. Pide por WhatsApp.`}
  page="home"
>
  <main class="page page-center hero" id="top">
    <div class="wrap hero-grid">
      <div class="hero-head">
        <span class="eyebrow">Galletas · Hechas con amor</span>
        <h1 style="margin-top:18px">Galletas artesanales
          <span class="ul">hechas con amor
            <svg viewBox="0 0 300 12" preserveAspectRatio="none"><path d="M3 8 C 70 2, 150 2, 297 6"/></svg>
          </span>
        </h1>
      </div>

      <div class="hero-visual">
        <div class="hero-plate"></div>
        <img class="hero-box" src="/assets/box-mediana.png" alt="Caja de galletas Galletas hechas con amor" />

        <a class="hero-price hp-0" href="/cajas" style="--accent:#CC8A3C" aria-label={`1 caja: S/${PRICING.unit}`}>
          <span class="hp-dot"></span>
          <b>S/{PRICING.unit}</b>
          <span class="hp-name">1 caja</span>
        </a>
        <a class="hero-price hp-1" href="/cajas" style="--accent:#87894C" aria-label={`2 cajas: S/${PRICING.pair}`}>
          <span class="hp-dot"></span>
          <b>S/{PRICING.pair}</b>
          <span class="hp-name">2 cajas</span>
        </a>

        <div class="hero-float f2">
          <span class="dot" style="background:#1FA855"></span>
          Entrega el 24
          <small>{DELIVERY.note}</small>
        </div>
      </div>

      <div class="hero-body">
        <p class="lead">Cajas surtidas de chocochips, chocolate, red velvet y coco, recién horneadas con ingredientes de verdad. Una caja de 6 galletas a S/{PRICING.unit}, o 2 cajas por S/{PRICING.pair}. Entrega el {DELIVERY.label}.</p>
        <div class="hero-actions">
          <a class="btn btn-lg" href="/cajas">Ver las cajas</a>
          <a class="btn btn-ghost btn-lg" href="/pedir">Hacer un pedido</a>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>
