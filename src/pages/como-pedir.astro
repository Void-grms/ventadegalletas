---
import BaseLayout from '../layouts/BaseLayout.astro';
import StepCard from '../components/StepCard.astro';
---
<BaseLayout title="Cómo pedir — Galletas" description="Pide tus galletas en menos de un minuto: elige tu caja, llena el formulario y confirma por WhatsApp." page="como">
  <main class="page page-center steps">
    <div class="wrap">
      <div class="page-head reveal">
        <span class="eyebrow">Así de fácil</span>
        <h1>Cómo pedir tus galletas</h1>
        <p>En menos de un minuto envías tu pedido por WhatsApp. Nosotros nos encargamos del resto.</p>
      </div>

      <div class="steps-grid">
        <div class="reveal">
          <StepCard num={1} title="Elige tu caja" text="Pequeña, Mediana o Grande, según cuántas galletas quieras.">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M3 9h18"/></svg>
          </StepCard>
        </div>
        <div class="reveal d1">
          <StepCard num={2} title="Llena el formulario" text="Sabor, cantidad y tus datos de entrega. Rápido y sin cuentas.">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 4h16v12H7l-3 3z"/></svg>
          </StepCard>
        </div>
        <div class="reveal d2">
          <StepCard num={3} title="Confirma por WhatsApp" text="Tu pedido llega armado a nuestro chat. Solo aprietas enviar.">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M.057 24l1.687-6.163A11.867 11.867 0 0 1 .16 11.89C.16 5.335 5.495 0 12.05 0c6.555 0 11.89 5.335 11.89 11.892S18.605 23.78 12.05 23.78a11.9 11.9 0 0 1-5.688-1.448z"/></svg>
          </StepCard>
        </div>
        <div class="reveal d3">
          <StepCard num={4} title="Recibe y disfruta" text="Coordinamos la entrega y tus galletas llegan fresquitas. ¡A disfrutar!">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 7h13v10H3zM16 10h3l2 3v4h-5M5.5 17.5a2 2 0 1 0 4 0 2 2 0 0 0-4 0M16.5 17.5a2 2 0 1 0 4 0 2 2 0 0 0-4 0"/></svg>
          </StepCard>
        </div>
      </div>

      <div class="page-cta reveal d2">
        <a class="btn btn-lg" href="/pedir">Empezar mi pedido</a>
      </div>
    </div>
  </main>
</BaseLayout>
