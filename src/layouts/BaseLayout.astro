---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import MobileMenu from '../components/MobileMenu.astro';
import WhatsAppFab from '../components/WhatsAppFab.astro';

const { title, description, page = '' } = Astro.props as {
  title: string;
  description?: string;
  page?: string;
};
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <ClientRouter />
  </head>
  <body>
    <div class="bg-decor" aria-hidden="true" transition:persist></div>
    <Header page={page} />
    <MobileMenu page={page} />
    <slot />
    <WhatsAppFab />
    <script>
      import { initMotion } from '../scripts/motion';
      const run = () => initMotion();
      document.addEventListener('astro:page-load', run);
    </script>
  </body>
</html>
